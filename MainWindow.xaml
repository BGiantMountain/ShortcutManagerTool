<Window x:Class="ShortcutManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="MainWindowEl" Title="Shortcut Manager" Height="620" Width="720"
        MinHeight="580" MinWidth="680"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        FontFamily="Segoe UI"
        Icon="Compatability 6.ico">

    <Window.Resources>

        <!-- ═══════════════════════════════════════
             BUTTON TEMPLATES
        ═══════════════════════════════════════ -->
        <ControlTemplate x:Key="GlowBtn" TargetType="Button">
            <Border x:Name="bd"
                    Background="{TemplateBinding Background}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
                <Border.Effect>
                    <DropShadowEffect Color="#666666" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                </Border.Effect>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#666666" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                        </Setter.Value>
                    </Setter>
                    <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="bd" Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#666666" BlurRadius="4" ShadowDepth="0" Opacity="0.5"/>
                        </Setter.Value>
                    </Setter>
                    <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="bd" Property="Opacity" Value="0.3"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="PlainBtn" TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}"
                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.85"/></Trigger>
                <Trigger Property="IsPressed"   Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.70"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter TargetName="bd" Property="Opacity" Value="0.30"/></Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template" Value="{StaticResource GlowBtn}"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#555555" Offset="0"/>
                        <GradientStop Color="#777777" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSuccess" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template" Value="{StaticResource GlowBtn}"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4A6E55" Offset="0"/>
                        <GradientStop Color="#5B8F6B" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="#404040"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template" Value="{StaticResource PlainBtn}"/>
        </Style>

        <Style x:Key="BtnPurple" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template" Value="{StaticResource PlainBtn}"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#555555" Offset="0"/>
                        <GradientStop Color="#777777" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════
             INPUT STYLES
        ═══════════════════════════════════════ -->
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0,8,0"/> <!-- FIX: PADDING KURTULDU -->
            <Setter Property="VerticalContentAlignment" Value="Center"/> <!-- FIX: YAZI DUVARA ÇARPMIYOR -->
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#666666"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#666666"/>
                                <Setter TargetName="bd" Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#777777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputReadOnly" BasedOn="{StaticResource Input}" TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderBrush" Value="#404040"/>
        </Style>

        <!-- ═══════════════════════════════════════
             TYPOGRAPHY
        ═══════════════════════════════════════ -->
        <Style x:Key="HeadingSmall" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Margin" Value="2,0,0,4"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0,0,0"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#666666"/>
        </Style>

        <!-- ═══════════════════════════════════════
             TAB CONTROL
        ═══════════════════════════════════════ -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                Background="Transparent">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="ic" Text="{TemplateBinding Tag}" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txt" Text="{TemplateBinding Header}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#666666"/>
                                <Setter TargetName="txt" Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="txt" Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="ic" Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="txt" Property="Foreground" Value="#CBD5E1"/>
                                <Setter TargetName="bd" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="#404040" BorderThickness="0,0,0,1" Background="#1C1C1C">
                                <TabPanel IsItemsHost="True" Background="Transparent" Margin="10,0"/>
                            </Border>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" Margin="14,14,14,8"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle" Value="{DynamicResource ComboBoxItemStyle}"/>
        </Style>

        <Style TargetType="TextBox" x:Key="ComboBoxTextBoxStyle">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style TargetType="ComboBoxItem" x:Key="ComboBoxItemStyle">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#404040"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#505050"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ═══════════════════════════════════════
             TREE VIEW
        ═══════════════════════════════════════ -->
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="#202020"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="4,3"/>
        </Style>

        <!-- ═══════════════════════════════════════
             SECTION CARD
        ═══════════════════════════════════════ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#111111" Offset="0"/>
                    <GradientStop Color="#202020" Offset="0.5"/>
                    <GradientStop Color="#151515" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔗" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="HeaderTitleTxt" Text="Shortcut Manager"
                                   Foreground="#F0F0F0" FontSize="18" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="HeaderSubtitleTxt" Text="Kısayol oluşturun · Onarın · Sanal modda çalıştırın"
                               Foreground="#64748B" FontSize="11" Margin="28,2,0,0"/>
                </StackPanel>

                <!-- Version badge & Lang Button -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="LangBtn" Content="🇬🇧 EN" Click="LangToggle_Click" Style="{StaticResource BtnGhost}" Margin="0,0,10,0"/>
                    <Border CornerRadius="6" VerticalAlignment="Center" Padding="10,4" Background="#404040" BorderBrush="#444444" BorderThickness="1">
                        <TextBlock Text="v2.1" Foreground="#E0E0E0" FontSize="11" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
        
        <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#66666600" Offset="0"/>
                    <GradientStop Color="#666666"   Offset="0.2"/>
                    <GradientStop Color="#777777"   Offset="0.8"/>
                    <GradientStop Color="#77777700" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- ═══ CONTENT ═══ -->
        <Border Grid.Row="1" Background="#1E1E1E">
            <TabControl>

                <!-- ╔══════════════════════════════════════
                     TAB 1: YENİ KISAYOL
                ══════════════════════════════════════╗ -->
                <TabItem x:Name="TabNewShortcut" Header="Yeni Kısayol" Tag="🛠️">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- ── 1. UYGULAMA KLASÖRÜ ── -->
                        <Border Grid.Row="0" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock x:Name="Step1Txt" Grid.Row="0" Text="01. UYGULAMA KLASÖRÜ" Style="{StaticResource HeadingSmall}"/>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="FolderPathTextBox" Style="{StaticResource Input}" Height="34"
                                             TextChanged="FolderPathTextBox_TextChanged"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                                        <Button x:Name="BtnBrowseFolder" Content="📂 Klasör Seç" Click="BrowseFolder_Click" Style="{StaticResource BtnGhost}" Width="100" Height="34"/>
                                        <CheckBox x:Name="ChkCreateFolderShortcut" Content="📁 Klasörü Kısayol Yap" Margin="12,0,0,0" ToolTip="Seçili klasörü gizle ve üst dizine kısayol at." VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- ── 2. ARAMA / FİLTRE ── -->
                        <Border Grid.Row="1" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="DepthTxt" Text="Derinlik" Foreground="#CBD5E1" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider Grid.Column="1" x:Name="DepthSlider" Minimum="1" Maximum="5" Value="3"
                                        TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1"
                                        VerticalAlignment="Center" ValueChanged="DepthSlider_ValueChanged"/>
                                
                                <TextBlock Grid.Column="2" Foreground="#E0E0E0" FontWeight="Bold" FontSize="11"
                                           VerticalAlignment="Center" Margin="6,0,16,0" Width="10"
                                           Text="{Binding ElementName=DepthSlider, Path=Value, StringFormat={}{0:0}}"/>

                                <TextBlock x:Name="SearchLblTxt" Grid.Column="3" Text="🔍 Arama:" Foreground="#CBD5E1" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                
                                <TextBox Grid.Column="4" x:Name="SearchTextBox" Style="{StaticResource Input}"
                                         Height="30" TextChanged="SearchTextBox_TextChanged"/>
                            </Grid>
                        </Border>

                        <!-- ── 3. LİSTE ── -->
                        <Border Grid.Row="2" CornerRadius="10" BorderBrush="#404040" BorderThickness="1"
                                Background="#202020" Margin="0,0,0,8" ClipToBounds="True">
                            <TreeView x:Name="ExeFilesTreeView"
                                      Background="Transparent" BorderThickness="0"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Items}">
                                        <StackPanel Orientation="Horizontal" Margin="2,4">
                                            <TextBlock Text="📁" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding FolderName}" Foreground="#E0E0E0" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <HierarchicalDataTemplate.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="2,2">
                                                    <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Foreground="#F0F0F0">
                                                        <TextBlock Text="{Binding FileName}" FontSize="12" Foreground="#F0F0F0" Margin="2,0,8,0" Width="150" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" ToolTip="{Binding FileName}"/>
                                                    </CheckBox>
                                                    <TextBox Text="{Binding CustomName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150" Height="22" 
                                                             Style="{StaticResource Input}" FontSize="11" 
                                                             ToolTip="Özel isim verin (boş bırakırsanız dosya adını alır)"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </HierarchicalDataTemplate.ItemTemplate>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Border>

                        <!-- ── 4. AYARLAR & OLUŞTUR ── -->
                        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Sanal Mod ve Kısayol Adı - YANYANA VE DAHA DÜZENLİ -->
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- FIX: CHECHBOX ILE YAZILAR ÇOK DAHA TEMİZ VE YAN YANA -->
                                    <CheckBox Grid.Column="0" x:Name="ChkVirtualRun"
                                              Content="🔴 Sanal Mod"
                                              ToolTip="Kapatınca otomatik silinen geçici mod."
                                              Margin="0,0,16,0" VerticalAlignment="Center" Foreground="#AAAAAA" FontWeight="SemiBold"/>

                                    <!-- Kısayol ismi listesi -->
                                </Grid>

                                <!-- İkon Seç ve Oluştur Butonları -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBox Grid.Column="0" x:Name="CustomIconPathTextBox" Style="{StaticResource Input}" Height="34" ToolTip="Özel .ico veya .exe seçin"/>
                                    <Button Grid.Column="1" x:Name="BtnBrowseIcon" Content="🎨 İkon Seç" Click="BrowseIcon_Click" Style="{StaticResource BtnPurple}" Width="90" Height="34" Margin="8,0,8,0"/>
                                    <Button Grid.Column="2" x:Name="BtnCreateDesktopShortcut" Content="🚀 Masaüstüne Kısayol Oluştur" Click="CreateShortcut_Click" Style="{StaticResource BtnSuccess}" Width="200" Height="34"/>
                                </Grid>
                            </Grid>
                        </Border>

                    </Grid>
                </TabItem>

                <!-- ╔══════════════════════════════════════
                     TAB 2: KISAYOL ONAR
                ══════════════════════════════════════╗ -->
                <TabItem x:Name="TabFixShortcut" Header="Kısayol Onar" Tag="✏️">
                    <Grid>
                        <!-- Kısayol Onar Kartı -->
                        <Border Style="{StaticResource Card}" VerticalAlignment="Top">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="16"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="StepFix1Txt" Grid.Row="0" Text="01. DÜZENLENECEK KISAYOL (.lnk)" Style="{StaticResource HeadingSmall}"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="EditLnkPathTextBox" Style="{StaticResource InputReadOnly}" Height="34" IsReadOnly="True"/>
                                    <Button Grid.Column="1" x:Name="BtnSelectShortcut" Content="📂 Kısayol Seç" Click="SelectLnkToEdit_Click" Style="{StaticResource BtnGhost}" Width="110" Height="34" Margin="8,0,0,0"/>
                                </Grid>

                                <TextBlock x:Name="StepFix2Txt" Grid.Row="3" Text="02. YENİ DEĞERLER" Style="{StaticResource HeadingSmall}"/>
                                <TextBlock x:Name="LblTargetTxt" Grid.Row="4" Text="Hedef Yol (Target Path)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Row="4" x:Name="EditTargetPathTextBox" Style="{StaticResource Input}" Height="34" Margin="0,18,0,0"/>

                                <TextBlock x:Name="LblWorkingTxt" Grid.Row="6" Text="Başlama Yeri (Working Directory)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Row="7" x:Name="EditWorkingDirTextBox" Style="{StaticResource Input}" Height="34" Margin="0,4,0,0"/>

                                <Button Grid.Row="9" x:Name="BtnSaveFix" Content="💾 Değişiklikleri Kaydet" Click="UpdateShortcut_Click" Style="{StaticResource BtnPrimary}" Height="40"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>


                <!-- ╔══════════════════════════════════════
                     TAB 3: KISAYOL TARAYICISI
                ══════════════════════════════════════╗ -->
                <TabItem x:Name="TabScanner" Header="Kısayol Tarayıcısı" Tag="🔎">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="ScannerDescTxt" Text="Sistem Diskleri veya Ağ Yolu (örn: \\Sunucu\Paylasim):" Style="{StaticResource HeadingSmall}" Margin="0,0,0,4"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="DrivesComboBox" Height="34" Margin="0,0,8,0" FontSize="13" 
                                              ItemsSource="{Binding SystemDrives}" DisplayMemberPath="Name" SelectedValuePath="RootDirectory.FullName"
                                              IsEditable="True" TextSearch.TextPath="Name" ToolTip="Bir disk seçin veya ağ adresi yazın">
                                        <ComboBox.Resources>
                                            <Style TargetType="{x:Type TextBox}">
                                                <Setter Property="Background" Value="#2D2D2D"/>
                                                <Setter Property="Foreground" Value="#E0E0E0"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                <Setter Property="Padding" Value="6,0,0,0"/>
                                            </Style>
                                        </ComboBox.Resources>
                                    </ComboBox>
                                    <Button x:Name="ScanBtn" Grid.Column="1" Content="Ara" Click="ScanShortcuts_Click" Style="{StaticResource BtnPrimary}" Width="100" Height="34"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" CornerRadius="10" BorderBrush="#404040" BorderThickness="1" Background="#202020" Margin="0,0,0,8" ClipToBounds="True">
                            <ListBox x:Name="ScannedShortcutsList" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" Foreground="#F0F0F0" Padding="4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="2,4">
                                            <TextBlock Text="🔗" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Width="180" Margin="0,0,8,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding Name}"/>
                                            <TextBlock Text="{Binding TargetPath}" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center" ToolTip="{Binding TargetPath}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                </TabItem>

            </TabControl>
        </Border>

        <!-- ═══ STATUS bar ═══ -->
        <Border Grid.Row="2" Background="#1C1C1C" BorderBrush="#2A2A2A" BorderThickness="0,1,0,0" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Ellipse Width="6" Height="6" Fill="#5B8F6B" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Grid.Column="1" x:Name="StatusLabel" Text="Hazır" Foreground="#777777" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="ShortcutManager  ·  © 2025" Foreground="#444444" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>