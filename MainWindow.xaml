<Window x:Class="ShortcutManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Akıllı Kısayol Merkezi" Height="620" Width="720"
        MinHeight="580" MinWidth="680"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        FontFamily="Segoe UI"
        Icon="Compatability 6.ico">

    <Window.Resources>

        <!-- ═══════════════════════════════════════
             BUTTON TEMPLATES
        ═══════════════════════════════════════ -->
        <ControlTemplate x:Key="GlowBtn" TargetType="Button">
            <Border x:Name="bd"
                    Background="{TemplateBinding Background}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
                <Border.Effect>
                    <DropShadowEffect Color="#3B82F6" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                </Border.Effect>
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#3B82F6" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                        </Setter.Value>
                    </Setter>
                    <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="bd" Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#3B82F6" BlurRadius="4" ShadowDepth="0" Opacity="0.5"/>
                        </Setter.Value>
                    </Setter>
                    <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="bd" Property="Opacity" Value="0.3"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="PlainBtn" TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}"
                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.85"/></Trigger>
                <Trigger Property="IsPressed"   Value="True"><Setter TargetName="bd" Property="Opacity" Value="0.70"/></Trigger>
                <Trigger Property="IsEnabled"   Value="False"><Setter TargetName="bd" Property="Opacity" Value="0.30"/></Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template" Value="{StaticResource GlowBtn}"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1D4ED8" Offset="0"/>
                        <GradientStop Color="#2563EB" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSuccess" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template" Value="{StaticResource GlowBtn}"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#059669" Offset="0"/>
                        <GradientStop Color="#10B981" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template" Value="{StaticResource PlainBtn}"/>
        </Style>

        <Style x:Key="BtnPurple" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template" Value="{StaticResource PlainBtn}"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#6D28D9" Offset="0"/>
                        <GradientStop Color="#8B5CF6" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════
             INPUT STYLES
        ═══════════════════════════════════════ -->
        <Style x:Key="Input" TargetType="TextBox">
            <Setter Property="Background" Value="#161B27"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0,8,0"/> <!-- FIX: PADDING KURTULDU -->
            <Setter Property="VerticalContentAlignment" Value="Center"/> <!-- FIX: YAZI DUVARA ÇARPMIYOR -->
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#3B82F6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="bd" Property="Background" Value="#172033"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputReadOnly" BasedOn="{StaticResource Input}" TargetType="TextBox">
            <Setter Property="Background" Value="#0F131D"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
        </Style>

        <!-- ═══════════════════════════════════════
             TYPOGRAPHY
        ═══════════════════════════════════════ -->
        <Style x:Key="HeadingSmall" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Margin" Value="2,0,0,4"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0,0,0"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#3B82F6"/>
        </Style>

        <!-- ═══════════════════════════════════════
             TAB CONTROL
        ═══════════════════════════════════════ -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                Background="Transparent">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="ic" Text="{TemplateBinding Tag}" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="txt" Text="{TemplateBinding Header}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="txt" Property="Foreground" Value="#FFFFFF"/>
                                <Setter TargetName="txt" Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="ic" Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="txt" Property="Foreground" Value="#CBD5E1"/>
                                <Setter TargetName="bd" Property="Background" Value="#111827"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="#1E293B" BorderThickness="0,0,0,1" Background="#0A0F1A">
                                <TabPanel IsItemsHost="True" Background="Transparent" Margin="10,0"/>
                            </Border>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent" Margin="14,14,14,8"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════
             TREE VIEW
        ═══════════════════════════════════════ -->
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="4,3"/>
        </Style>

        <!-- ═══════════════════════════════════════
             SECTION CARD
        ═══════════════════════════════════════ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#101726"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#020617" Offset="0"/>
                    <GradientStop Color="#0F172A" Offset="0.5"/>
                    <GradientStop Color="#170B2A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔗" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Akıllı Kısayol Merkezi"
                                   Foreground="#F8FAFC" FontSize="18" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Kısayol oluşturun · Onarın · Sanal modda çalıştırın"
                               Foreground="#64748B" FontSize="11" Margin="28,2,0,0"/>
                </StackPanel>

                <!-- Version badge -->
                <Border Grid.Column="1" CornerRadius="6" VerticalAlignment="Center" Padding="10,4" Background="#1E293B" BorderBrush="#334155" BorderThickness="1">
                    <TextBlock Text="v2.0" Foreground="#60A5FA" FontSize="11" FontWeight="Bold"/>
                </Border>
            </Grid>
        </Border>
        
        <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#3B82F600" Offset="0"/>
                    <GradientStop Color="#3B82F6"   Offset="0.2"/>
                    <GradientStop Color="#8B5CF6"   Offset="0.8"/>
                    <GradientStop Color="#8B5CF600" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- ═══ CONTENT ═══ -->
        <Border Grid.Row="1" Background="#0D1117">
            <TabControl>

                <!-- ╔══════════════════════════════════════
                     TAB 1: YENİ KISAYOL
                ══════════════════════════════════════╗ -->
                <TabItem Header="Yeni Kısayol" Tag="🛠️">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- ── 1. UYGULAMA KLASÖRÜ ── -->
                        <Border Grid.Row="0" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Text="01. UYGULAMA KLASÖRÜ" Style="{StaticResource HeadingSmall}"/>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="FolderPathTextBox" Style="{StaticResource Input}" Height="34"
                                             TextChanged="FolderPathTextBox_TextChanged"/>
                                    <Button Grid.Column="1" Content="📂 Klasör Seç"
                                            Click="BrowseFolder_Click"
                                            Style="{StaticResource BtnGhost}" Width="100" Height="34" Margin="8,0,0,0"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- ── 2. ARAMA / FİLTRE ── -->
                        <Border Grid.Row="1" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Derinlik" Foreground="#CBD5E1" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Slider Grid.Column="1" x:Name="DepthSlider" Minimum="1" Maximum="5" Value="3"
                                        TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1"
                                        VerticalAlignment="Center" ValueChanged="DepthSlider_ValueChanged"/>
                                
                                <TextBlock Grid.Column="2" Foreground="#60A5FA" FontWeight="Bold" FontSize="11"
                                           VerticalAlignment="Center" Margin="6,0,16,0" Width="10"
                                           Text="{Binding ElementName=DepthSlider, Path=Value, StringFormat={}{0:0}}"/>

                                <TextBlock Grid.Column="3" Text="🔍 Arama:" Foreground="#CBD5E1" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                
                                <TextBox Grid.Column="4" x:Name="SearchTextBox" Style="{StaticResource Input}"
                                         Height="30" TextChanged="SearchTextBox_TextChanged"/>
                            </Grid>
                        </Border>

                        <!-- ── 3. LİSTE ── -->
                        <Border Grid.Row="2" CornerRadius="10" BorderBrush="#1E293B" BorderThickness="1"
                                Background="#0F172A" Margin="0,0,0,8" ClipToBounds="True">
                            <TreeView x:Name="ExeFilesTreeView"
                                      Background="Transparent" BorderThickness="0"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Items}">
                                        <StackPanel Orientation="Horizontal" Margin="2,4">
                                            <TextBlock Text="📁" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding FolderName}" Foreground="#60A5FA" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <HierarchicalDataTemplate.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected}" Margin="2,2" Foreground="#F8FAFC">
                                                    <CheckBox.Content>
                                                        <StackPanel Orientation="Horizontal" Margin="2,0,0,0">
                                                            <TextBlock Text="{Binding FileName}" FontSize="12" Foreground="#F8FAFC"/>
                                                        </StackPanel>
                                                    </CheckBox.Content>
                                                </CheckBox>
                                            </DataTemplate>
                                        </HierarchicalDataTemplate.ItemTemplate>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Border>

                        <!-- ── 4. AYARLAR & OLUŞTUR ── -->
                        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Sanal Mod ve Kısayol Adı - YANYANA VE DAHA DÜZENLİ -->
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- FIX: CHECHBOX ILE YAZILAR ÇOK DAHA TEMİZ VE YAN YANA -->
                                    <CheckBox Grid.Column="0" x:Name="ChkVirtualRun"
                                              Content="🔴 Sanal Mod"
                                              ToolTip="Kapatınca otomatik silinen geçici mod."
                                              Margin="0,0,16,0" VerticalAlignment="Center" Foreground="#FB923C" FontWeight="SemiBold"/>

                                    <Grid Grid.Column="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Kısayol Adı:" VerticalAlignment="Center" Style="{StaticResource FieldLabel}" Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="1" x:Name="ShortcutNameTextBox" Height="32" Style="{StaticResource Input}"/>
                                    </Grid>
                                </Grid>

                                <!-- İkon Seç ve Oluştur Butonları -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBox Grid.Column="0" x:Name="CustomIconPathTextBox" Style="{StaticResource Input}" Height="34" ToolTip="Özel .ico veya .exe seçin"/>
                                    <Button Grid.Column="1" Content="🎨 İkon Seç" Click="BrowseIcon_Click" Style="{StaticResource BtnPurple}" Width="90" Height="34" Margin="8,0,8,0"/>
                                    <Button Grid.Column="2" Content="🚀 Masaüstüne Kısayol Oluştur" Click="CreateShortcut_Click" Style="{StaticResource BtnSuccess}" Width="200" Height="34"/>
                                </Grid>
                            </Grid>
                        </Border>

                    </Grid>
                </TabItem>

                <!-- ╔══════════════════════════════════════
                     TAB 2: KISAYOL ONAR
                ══════════════════════════════════════╗ -->
                <TabItem Header="Kısayol Onar" Tag="✏️">
                    <Grid>
                        <!-- Kısayol Onar Kartı -->
                        <Border Style="{StaticResource Card}" VerticalAlignment="Top">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="16"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="01. DÜZENLENECEK KISAYOL (.lnk)" Style="{StaticResource HeadingSmall}"/>
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="EditLnkPathTextBox" Style="{StaticResource InputReadOnly}" Height="34" IsReadOnly="True"/>
                                    <Button Grid.Column="1" Content="📂 Kısayol Seç" Click="SelectLnkToEdit_Click" Style="{StaticResource BtnGhost}" Width="110" Height="34" Margin="8,0,0,0"/>
                                </Grid>

                                <TextBlock Grid.Row="3" Text="02. YENİ DEĞERLER" Style="{StaticResource HeadingSmall}"/>
                                <TextBlock Grid.Row="4" Text="Hedef Yol (Target Path)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Row="4" x:Name="EditTargetPathTextBox" Style="{StaticResource Input}" Height="34" Margin="0,18,0,0"/>

                                <TextBlock Grid.Row="6" Text="Başlama Yeri (Working Directory)" Style="{StaticResource FieldLabel}"/>
                                <TextBox Grid.Row="7" x:Name="EditWorkingDirTextBox" Style="{StaticResource Input}" Height="34" Margin="0,4,0,0"/>

                                <Button Grid.Row="9" Content="💾 Değişiklikleri Kaydet" Click="UpdateShortcut_Click" Style="{StaticResource BtnPrimary}" Height="40"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

            </TabControl>
        </Border>

        <!-- ═══ STATUS bar ═══ -->
        <Border Grid.Row="2" Background="#0A0F1A" BorderBrush="#111827" BorderThickness="0,1,0,0" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Ellipse Width="6" Height="6" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Grid.Column="1" x:Name="StatusLabel" Text="Hazır" Foreground="#475569" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="ShortcutManager  ·  © 2025" Foreground="#334155" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>