<Window x:Class="ShortcutManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Akıllı Kısayol Merkezi" Height="550" Width="600"
        WindowStartupLocation="CenterScreen" Background="#F0F3F4"
        Icon="Compatability 6.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="🔗 Akıllı Kısayol Merkezi" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
            <TextBlock Text="Kısayol oluşturun, onarın ve uygulama ayarlarını senkronize edin." FontSize="12" Foreground="#7F8C8D" Margin="0,2,0,0"/>
        </StackPanel>

        <TabControl Grid.Row="1" Background="White" BorderBrush="#E0E6ED" Padding="10">

            <TabItem Header="🛠️ Yeni Kısayol Üret" FontSize="14" FontWeight="SemiBold" Foreground="#34495E">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="1. Uygulama Klasörünü Seçin (veya yolunu yapıştırın)" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,2"/>
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="FolderPathTextBox" Height="30" Padding="8,4" FontSize="13" Background="#F8F9F9" BorderBrush="#BDC3C7" BorderThickness="1" TextChanged="FolderPathTextBox_TextChanged"/>
                        <Button Grid.Column="1" Content="Klasör Seç..." Click="BrowseFolder_Click" Width="85" Margin="5,0,0,0" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </Grid>

                    <!-- Satir 2: Derinlik + Arama -->
                    <Grid Grid.Row="2" Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Derinlik:" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#666" FontSize="11"/>
                        <Slider Grid.Column="1" x:Name="DepthSlider" Minimum="1" Maximum="5" Value="3" TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1" VerticalAlignment="Center" Margin="0,0,3,0" ValueChanged="DepthSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" Text="{Binding ElementName=DepthSlider, Path=Value, StringFormat={}{0:0}}" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#2980B9" FontWeight="Bold" FontSize="11" Width="12"/>
                        <TextBlock Grid.Column="3" Text="Ara: " VerticalAlignment="Center" Foreground="#666" FontSize="11" Margin="0,0,2,0"/>
                        <TextBox Grid.Column="4" x:Name="SearchTextBox" Height="24" Padding="4,2" FontSize="12" BorderBrush="#27AE60" BorderThickness="1" Text="" TextChanged="SearchTextBox_TextChanged"/>
                    </Grid>

                    <!-- Row 3: Exe TreeView -->
                    <TreeView Grid.Row="3" x:Name="ExeFilesTreeView" MinHeight="80" Margin="0,0,0,8" Background="#F8F9F9" BorderBrush="#BDC3C7" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Items}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📁 " FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding FolderName}" FontWeight="SemiBold" Foreground="#2C3E50" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" Margin="2,1">
                                            <CheckBox.Content>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="⚙️ " FontSize="11"/>
                                                    <TextBlock Text="{Binding FileName}" FontSize="12"/>
                                                </StackPanel>
                                            </CheckBox.Content>
                                        </CheckBox>
                                    </DataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <TextBlock Grid.Row="4" Text="3. Seçenekler" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,2" FontSize="12"/>
                    <CheckBox Grid.Row="5" x:Name="ChkVirtualRun" Content="🔴 Sanal Mod: Uygulamayı geçici olarak bilgisayara kopyala, çalıştır, kapatınca sil" ToolTip="Program kapandığında geçici kopya otomatik silinir. Ağ uygulama uyumsuzluğu için idealdir." Foreground="#D35400" Margin="0,0,0,6" FontSize="12"/>

                    <TextBlock Grid.Row="7" Text="4. Kısayol Adı Ön Eki (Boş Bırakılırsa Exe Adı Kullanılır)" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,2" FontSize="12"/>
                    <TextBox Grid.Row="8" x:Name="ShortcutNameTextBox" Height="28" Padding="6,4" FontSize="12" Background="#F8F9F9" BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,6" ToolTip="Masaüstünde bu isimle oluşturulur"/>

                    <TextBlock Grid.Row="9" Text="5. Özel İkon Seç (.ico veya .exe) — Boş ise exe’nin kendi ikonu kullanılır" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,2" FontSize="12"/>
                    <Grid Grid.Row="10" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="CustomIconPathTextBox" Height="28" Padding="6,4" FontSize="12" Background="#F8F9F9" BorderBrush="#BDC3C7" BorderThickness="1"/>
                        <Button Grid.Column="1" Content="İkon Seç..." Click="BrowseIcon_Click" Width="85" Margin="5,0,0,0" Background="#8E44AD" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </Grid>

                    <Button Grid.Row="11" Content="🚀 Masaüstüne Kısayol Oluştur" Click="CreateShortcut_Click" Height="38" Background="#27AE60" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                </Grid>
            </TabItem>

            <TabItem Header="✏️ Kısayol Onar" FontSize="14" FontWeight="SemiBold" Foreground="#34495E">
                <StackPanel Margin="10">
                    <TextBlock Text="1. Düzenlenecek Kısayolu Seçin (.lnk)" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,2"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="EditLnkPathTextBox" Height="30" Padding="8,4" FontSize="13" Background="#E8F8F5" BorderBrush="#BDC3C7" BorderThickness="1" IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="Kısayol Seç..." Click="SelectLnkToEdit_Click" Width="85" Margin="5,0,0,0" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </Grid>

                    <TextBlock Text="2. Yeni Hedef Yol (Target Path)" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,2"/>
                    <TextBox x:Name="EditTargetPathTextBox" Height="30" Padding="8,4" FontSize="13" Background="#F8F9F9" BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,10"/>

                    <TextBlock Text="3. Yeni Başlama Yeri (Working Directory)" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,2"/>
                    <TextBox x:Name="EditWorkingDirTextBox" Height="30" Padding="8,4" FontSize="13" Background="#F8F9F9" BorderBrush="#BDC3C7" BorderThickness="1" Margin="0,0,0,15"/>

                    <Button Content="💾 Değişiklikleri Kaydet" Click="UpdateShortcut_Click" Height="40" Background="#2980B9" Foreground="White" FontSize="15" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Window>